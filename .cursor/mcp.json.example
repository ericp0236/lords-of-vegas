{
  "mcpServers": {
    "supabase": {
      "url": "https://mcp.supabase.com/mcp?project_ref=YOUR_PROJECT_REF"
    },
    "rive": {
      "url": "http://127.0.0.1:9791/mcp"
    },
    "higgsfield": {
      "url": "https://mcp.higgsfield.ai/mcp"
    },
    "ludo-ai": {
      "url": "https://mcp.ludo.ai/mcp",
      "envFile": "${workspaceFolder}/.cursor/mcp-servers/ludo-ai/.env",
      "headers": {
        "Authentication": "ApiKey ${env:LUDO_API_KEY}"
      }
    },
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"]
    }
  }
}
